{
  "name": "server",
  "scripts": {
    "dev": "bun run src/index.ts",
    "dev:wrangler": "wrangler dev",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "RUN_INTEGRATION_TESTS=true vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "deploy": "wrangler deploy",
    "deploy:dry": "wrangler deploy --dry-run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1081.0",
    "@aws-sdk/s3-request-presigner": "^3.1081.0",
    "@better-auth/api-key": "^1.6.23",
    "@hono/zod-validator": "^0.8.0",
    "@neondatabase/serverless": "^1.1.0",
    "@scalar/hono-api-reference": "^0.11.9",
    "awilix": "^13.0.5",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^1.0.0-rc.4",
    "hono": "^4.12.27",
    "resend": "^6.17.1",
    "slugify": "^1.6.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260717.1",
    "@types/node": "^24",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^1.0.0-rc.4",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
