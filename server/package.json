    "@hono/zod-validator": "^0.8.0",
    "@scalar/hono-api-reference": "^0.11.9",
    "awilix": "^13.0.5",
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-rc.4",
    "hono": "^4.12.27",
    "pg": "^8.22.0",
    "resend": "^6.17.1",
    "slugify": "^1.6.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^1.0.0-rc.4",
    "oxfmt": "0.58.0",
