DATABASE_URL=postgresql://user:password@localhost:5432/aska

BETTER_AUTH_SECRET=replace-with-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000

RESEND_API_KEY=re_xxxxxxxxxxxx

CORS_ORIGINS=http://localhost:5173,http://localhost:5174
PORT=3000
NODE_ENV=development

S3_BUCKET=aska-dev
S3_REGION=eu-central-1
# Leave credentials unset to use your AWS profile locally. Set S3_ENDPOINT and
# the key pair only when using an S3-compatible local emulator.
# S3_ENDPOINT=http://localhost:4566
# S3_ACCESS_KEY_ID=test
# S3_SECRET_ACCESS_KEY=test
S3_PRESIGNED_UPLOAD_EXPIRES_SECONDS=900
S3_PRESIGNED_READ_EXPIRES_SECONDS=900
MAX_DIRECT_UPLOAD_BYTES=20971520

IMAGE_PIPELINE_CALLBACK_SECRET=replace-with-at-least-32-characters
