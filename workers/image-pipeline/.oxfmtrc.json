{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"printWidth": 80,
	"tabWidth": 2,
	"useTabs": true,
	"semi": true,
	"singleQuote": false,
	"trailingComma": "all",
	"ignorePatterns": [
		"node_modules/**",
		"coverage/**",
		"AGENTS.md",
		"worker-configuration.d.ts",
		".vscode/**"
	]
}
